# Shopify Store Configuration
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpss_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10

# Storefront API Token
# Obtenir dans: Admin > Apps > Développer des apps > ton app > Storefront API
SHOPIFY_STOREFRONT_TOKEN=

# Shopify App credentials
# Obtenir dans: Admin > Apps > Développer des apps > ton app
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Cloudflare Worker
# URL du Worker après déploiement (ex: https://moona-rituels.ton-subdomain.workers.dev)
WORKER_URL=
